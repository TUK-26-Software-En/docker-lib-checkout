# ==============================================
# PostgreSQL Database
# ==============================================
POSTGRES_HOST=postgres           # docker service name (use "localhost" for local dev)
POSTGRES_PORT=5432               # host-side port mapping (PostgreSQL default: 5432)
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# Table names (SQLAlchemy __tablename__)
DB_TABLE_BOOKS=books
DB_TABLE_MEMBERS=members
DB_TABLE_LOANS=loans

# ==============================================
# Container Ports (host-side mapping)
# ==============================================
LIBRARY_PORT=8000                # http://localhost:${LIBRARY_PORT}
MONITOR_PORT=8001                # http://localhost:${MONITOR_PORT}

# ==============================================
# Library Checkout App
# ==============================================
APP_TITLE=도서 대출 관리 시스템
APP_ENV=production               # production | development
LOG_LEVEL=info                   # debug | info | warning | error

# ==============================================
# Health Monitoring
# ==============================================
# LIBRARY_URL uses docker internal service name, not the host port
LIBRARY_URL=http://library-checkout:8000
POLL_INTERVAL=30                 # seconds between health checks
MAX_HISTORY=20                   # number of check records to keep
